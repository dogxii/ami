{
  "name": "@dogxi/ami",
  "version": "0.3.0",
  "description": "A lightweight terminal agent CLI with simple tool calling.",
  "type": "module",
  "bin": {
    "ami": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "assets/preview.webp"
  ],
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup && chmod +x dist/cli.js",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "cli",
    "agent",
    "llm",
    "tool-call"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "cac": "^7.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
